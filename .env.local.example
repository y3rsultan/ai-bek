# Supabase (get from supabase.com → your project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Telegram Bot (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Groq AI (get from console.groq.com → API Keys)
GROQ_API_KEY=gsk_your_key_here

# App URL (your Vercel deployment URL)
NEXT_PUBLIC_APP_URL=https://ai-bek.vercel.app
